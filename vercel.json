{
  "crons": [
    {
      "path": "/api/workflows/chat/maintenance",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/workflows/rag/reindex",
      "schedule": "0 4 * * 0"
    }
  ],
  "routes": [
    {
      "src": "/api/workflows/(.*)",
      "missing": [
        {
          "type": "header",
          "key": "x-vercel-cron"
        }
      ],
      "mitigate": {
        "action": "deny"
      }
    }
  ]
}
