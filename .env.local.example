AI_GATEWAY_API_KEY=your-vercel-ai-gateway-api-key-here
VERCEL_OIDC_TOKEN=your-vercel-oidc-token-here
DATABASE_URL=your-neon-postgres-url-here

# Upstash Redis — rate limiting (also accepted as KV_REST_API_* aliases)
UPSTASH_REDIS_REST_URL=your-upstash-rest-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here
KV_REST_API_URL=your-upstash-rest-url-here
KV_REST_API_TOKEN=your-upstash-rest-token-here

# Vercel Blob — user document uploads
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here

# Basic Auth (optional — omit both to disable auth)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=your-password-here
